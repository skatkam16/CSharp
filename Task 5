class Program
{
    public static void Main(string[] args)
    {
        int[] numbers = new int[10];
        Console.WriteLine("Enter 10 Numbers");
        for(int i = 0; i < 10; i++)
        {
            numbers[i]=int.Parse(Console.ReadLine());
        }
        Console.WriteLine("Even Numbers are - ");
        for (int i= 0; i < 10; i++)
        {
            if (numbers[i] % 2 == 0)
            {
                Console.WriteLine(numbers[i]);
            }
        }
    }
}
