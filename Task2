using System;

namespace PersonApp
{
    class Person
    {
        public string Name { get; set; }

        public Person(string name)
        {
            Name = name;
        }

        public override string ToString()
        {
            return Name;
        }
    }

    class Student : Person
    {
        public Student(string name) : base(name) { }

        public void Study()
        {
            Console.WriteLine(Name + " is Studying");
        }
    }

    class Teacher : Person
    {
        public Teacher(string name) : base(name) { }

        public void Explain()
        {
            Console.WriteLine(Name + " is Explaining");
        }
    }

    class Program
    {
        public static void Main(string[] args)
        {
            Person[] people = new Person[3];

            Console.WriteLine("Enter 1st Student Name - ");
            string name1;
            while (string.IsNullOrWhiteSpace(name1 = Console.ReadLine()))
            {
                Console.Write("Invalid input. Enter again: ");
            }
            people[0] = new Student(name1);

            Console.WriteLine("Enter 2nd Student Name - ");
            string name2;
            while (string.IsNullOrWhiteSpace(name2 = Console.ReadLine()))
            {
                Console.Write("Invalid input. Enter again: ");
            }
            people[1] = new Student(name2);

            Console.WriteLine("Enter Teacher Name - ");
            string name3;
            while (string.IsNullOrWhiteSpace(name3 = Console.ReadLine()))
            {
                Console.Write("Invalid input. Enter again: ");
            }
            people[2] = new Teacher(name3);

            foreach (Person person in people)
            {
                if (person is Student s)
                {
                    s.Study();
                }
                else if (person is Teacher t)
                {
                    t.Explain();
                }
            }
        }
    }
}
